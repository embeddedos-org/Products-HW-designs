    )
    (net (code 6) (name "GND")
      (node (ref U1)  (pin "GND1"))
      (node (ref U1)  (pin "GND2"))
      (node (ref U2)  (pin "2"))
      (node (ref U3)  (pin "GND1"))
      (node (ref U3)  (pin "GND2"))
      (node (ref U4)  (pin "GND"))
      (node (ref U5)  (pin "GND"))
      (node (ref U6)  (pin "5"))
      (node (ref U7)  (pin "24"))
      (node (ref D1)  (pin "K"))
      (node (ref J1)  (pin "2"))
      (node (ref J3)  (pin "8"))
    )

    ;; ── SPI0: Main MCU ↔ FPGA ─────────────────────────────
    (net (code 10) (name "SPI0_CS")
      (node (ref U1) (pin "PA0"))
      (node (ref U3) (pin "CSI_B"))
    )
    (net (code 11) (name "SPI0_CLK")
      (node (ref U1) (pin "PA1"))
      (node (ref U3) (pin "CCLK"))
    )
    (net (code 12) (name "SPI0_MOSI")
      (node (ref U1) (pin "PA2"))
      (node (ref U3) (pin "DIN"))
    )
    (net (code 13) (name "SPI0_MISO")
      (node (ref U1) (pin "PA3"))
      (node (ref U3) (pin "DOUT"))
    )

    ;; ── I2C0: shared bus ──────────────────────────────────
    (net (code 20) (name "I2C0_SDA")
      (node (ref U1) (pin "PB0"))
      (node (ref U2) (pin "1"))
      (node (ref U4) (pin "IOM0_SDA"))
      (node (ref U7) (pin "21"))
      (node (ref R1) (pin "2"))
    )
    (net (code 21) (name "I2C0_SCL")
      (node (ref U1) (pin "PB1"))
      (node (ref U2) (pin "5"))
      (node (ref U4) (pin "IOM0_SCL"))
      (node (ref U7) (pin "22"))
      (node (ref R2) (pin "2"))
    )

    ;; ── UART0: MCU ↔ Radio ────────────────────────────────
    (net (code 30) (name "UART0_TX")
      (node (ref U1) (pin "PC0"))
      (node (ref J3) (pin "1"))
    )
    (net (code 31) (name "UART0_RX")
      (node (ref U1) (pin "PC1"))
      (node (ref J3) (pin "2"))
    )
    (net (code 32) (name "UART0_CTS")
      (node (ref U1) (pin "PC2"))
      (node (ref J3) (pin "3"))
    )
    (net (code 33) (name "UART0_RTS")
      (node (ref U1) (pin "PC3"))
      (node (ref J3) (pin "4"))
    )

    ;; ── Memory bus: MCU+FPGA ↔ ECC SDRAM ─────────────────
    (net (code 40) (name "MEM_DQ0")
      (node (ref U1) (pin "PD0"))
      (node (ref U3) (pin "DQ0"))
      (node (ref U5) (pin "DQ0"))
    )
    (net (code 41) (name "MEM_DQ1")
      (node (ref U1) (pin "PD1"))
      (node (ref U3) (pin "DQ1"))
      (node (ref U5) (pin "DQ1"))
    )
    (net (code 47) (name "MEM_DQ7")
      (node (ref U1) (pin "PD7"))
      (node (ref U3) (pin "DQ7"))
      (node (ref U5) (pin "DQ7"))
    )
    (net (code 50) (name "MEM_A0")
      (node (ref U1) (pin "PD16"))
      (node (ref U3) (pin "MA0"))
      (node (ref U5) (pin "A0"))
    )
    (net (code 55) (name "MEM_WE_B")
      (node (ref U1) (pin "PD21"))
      (node (ref U5) (pin "WE_B"))
    )
    (net (code 56) (name "MEM_CS_B")
      (node (ref U1) (pin "PD22"))
      (node (ref U5) (pin "CS_B"))
    )

    ;; ── GPIO / Control nets ───────────────────────────────
    (net (code 60) (name "GPIO_IRQ_SE")
      (node (ref U1) (pin "PE0"))
      (node (ref U2) (pin "7"))
      (node (ref R3) (pin "2"))
    )
    (net (code 61) (name "GPIO_IRQ_FPGA")
      (node (ref U1) (pin "PE1"))
      (node (ref U3) (pin "FAULT_IRQ"))
    )
    (net (code 62) (name "GPIO_nRST_FPGA")
      (node (ref U1) (pin "PE2"))
      (node (ref R4) (pin "1"))
    )
    (net (code 63) (name "FPGA_PROG_B")
      (node (ref R4) (pin "2"))
      (node (ref U3) (pin "PROG_B"))
    )
    (net (code 64) (name "FPGA_DONE")
      (node (ref U1) (pin "PE3"))
      (node (ref U3) (pin "DONE"))
    )
    (net (code 65) (name "WAKE_MAIN")
      (node (ref U4) (pin "GPIO0"))
      (node (ref U1) (pin "PE4"))
    )
    (net (code 66) (name "EN_MCU")
      (node (ref U4) (pin "GPIO1"))
      (node (ref U7) (pin "EN1"))
    )
    (net (code 67) (name "EN_FPGA")
      (node (ref U4) (pin "GPIO2"))
      (node (ref U7) (pin "EN2"))
    )
    (net (code 68) (name "EN_RADIO")
      (node (ref U4) (pin "GPIO3"))
      (node (ref J3) (pin "5"))
    )

    ;; ── SPI2: FPGA ↔ Radio baseband ──────────────────────
    (net (code 70) (name "SPI2_CLK")
      (node (ref U3) (pin "K5"))
      (node (ref J3) (pin "6"))
    )
    (net (code 71) (name "SPI2_DO")
      (node (ref U3) (pin "K6"))
      (node (ref J3) (pin "7"))
    )

    ;; ── JTAG ─────────────────────────────────────────────
    (net (code 80) (name "JTAG_TMS")
      (node (ref U1) (pin "JTAG_TMS"))
      (node (ref J2) (pin "2"))
    )
    (net (code 81) (name "JTAG_TCK")
      (node (ref U1) (pin "JTAG_TCK"))
      (node (ref J2) (pin "4"))
    )
    (net (code 82) (name "JTAG_TDO")
      (node (ref U1) (pin "JTAG_TDO"))
      (node (ref J2) (pin "6"))
    )
    (net (code 83) (name "JTAG_TDI")
      (node (ref U1) (pin "JTAG_TDI"))
      (node (ref J2) (pin "8"))
    )
    (net (code 84) (name "MCU_nRST")
      (node (ref U1) (pin "NRSTB"))
      (node (ref J2) (pin "10"))
      (node (ref R5) (pin "2"))
    )

    ;; ── Crystal ──────────────────────────────────────────
    (net (code 90) (name "XTAL_32K_OUT")
      (node (ref U4) (pin "XO32"))
      (node (ref Y1) (pin "1"))
    )
    (net (code 91) (name "XTAL_32K_IN")
      (node (ref U4) (pin "XI32"))
      (node (ref Y1) (pin "2"))
    )

  )
)
